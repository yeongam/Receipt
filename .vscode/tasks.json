{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Xcode Build macOS (ORICO safe)",
      "type": "shell",
      "command": "/Users/user/.codex/orico-flutter-xcode-build.zsh",
      "args": [
        "${workspaceFolder}",
        "macos",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Xcode Build iOS Simulator (ORICO safe)",
      "type": "shell",
      "command": "/Users/user/.codex/orico-flutter-xcode-build.zsh",
      "args": [
        "${workspaceFolder}",
        "ios",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
